# SpeedPy environment variables
# Copy this file to .env and adjust values for your environment.

# --- Core ---
# DEBUG=True
# SECRET_KEY=change_me
# DATABASE_URL=sqlite:///db.sqlite3
# ALLOWED_HOSTS=*

# --- Email ---
# EMAIL_PROVIDER selects the sending backend used behind django-post_office.
# One of: console (dev default), smtp, ses, mailgun, sendgrid, postmark, resend.
# An unknown value fails loudly at startup.
# EMAIL_PROVIDER=console
# DEFAULT_FROM_EMAIL=admin@example.com
# SERVER_EMAIL=admin@example.com   # defaults to DEFAULT_FROM_EMAIL
#
# smtp: connection comes from EMAIL_URL
# EMAIL_URL=smtp://user:password@smtp.example.com:587/?tls=True
#
# API providers (django-anymail). Placeholders boot the app; real keys needed to send.
# ses (AWS SES):
# AWS_SES_ACCESS_KEY_ID=change_me
# AWS_SES_SECRET_ACCESS_KEY=change_me
# AWS_SES_REGION_NAME=eu-central-1
# mailgun:
# MAILGUN_API_KEY=change_me
# MAILGUN_SENDER_DOMAIN=example.com
# MAILGUN_API_URL=https://api.mailgun.net/v3   # use https://api.eu.mailgun.net/v3 for EU
# sendgrid:
# SENDGRID_API_KEY=change_me
# postmark:
# POSTMARK_SERVER_TOKEN=change_me
# resend:
# RESEND_API_KEY=change_me

# --- CORS ---
# Only needed for browser-based SPA clients and OAuth2 interactive flows.
# Server-to-server and CLI clients use PAT/JWT and do not need CORS.
#
# In DEBUG mode, CORS_ALLOW_ALL_ORIGINS defaults to True for local dev.
# A startup guard prevents CORS_ALLOW_ALL_ORIGINS=True when DEBUG=False.
#
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOW_CREDENTIALS=False
